# Template for the .env file the CD server should keep next to docker-compose.yml.
# Copy this to `.env` on the server and fill in real values:
#     cp .env.production.example .env
#
# `.env` itself is gitignored — do NOT commit secrets.

# --- Image to deploy ---
# CI publishes a tag (typically the commit SHA). The server points APP_IMAGE
# at the image it wants to run; `docker compose pull && docker compose up -d`
# rolls forward.
APP_IMAGE=ghcr.io/your-org/ecommerce-spring:latest

# --- Host port the app is reachable on (mapped to container port 8080) ---
APP_PORT=7410

# --- Database (created automatically inside the `db` container on first boot) ---
POSTGRES_DB=ecommerce_db
POSTGRES_USER=ecom
POSTGRES_PASSWORD=change-me-to-a-strong-random-value

# --- Mail / SMTP (Gmail App Password recommended, NOT your real password) ---
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=you@example.com
SPRING_MAIL_PASSWORD=your-app-password

# --- Cloudinary (image uploads) ---
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=your-secret

# --- JVM tuning (optional override) ---
# JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0 -Xss512k
